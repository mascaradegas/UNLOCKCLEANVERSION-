{
  "name": "unlock2026",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npx vite --port 3005 --open",
    "start": "cd apps/web && npx vite --port 3005 --open",
    "build": "cd apps/web && npm run build",
    "install-all": "npm install && cd apps/web && npm install",
    "validate": "npm run validate:lessons",
    "validate:lessons": "node scripts/validate-lessons.mjs",
    "organize": "node organize-lessons-auto.js",
    "organize:manual": "node organize-lessons.js"
  }
}
